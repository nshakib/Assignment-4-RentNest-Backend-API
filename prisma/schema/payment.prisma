model Payment {
  id              String        @id @default(uuid())

  rentalRequestId String
  tenantId        String

  amount          Decimal       @db.Decimal(10, 2)
  monthNumber     Int           // which month of the lease this payment covers (1, 2, 3...)

  status          PaymentStatus @default(PENDING)

  stripePaymentIntentId String? @unique
  paidAt          DateTime?
  failureReason   String?       @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  rentalRequest   RentalRequest @relation(fields: [rentalRequestId], references: [id], onDelete: Cascade)
  tenant          User          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([rentalRequestId, monthNumber]) // prevents double-paying the same month
  @@index([tenantId])
  @@index([rentalRequestId])

  @@map("payment")
}